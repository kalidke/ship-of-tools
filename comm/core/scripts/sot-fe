#!/usr/bin/env bash
# sot-fe — drive the Ship of Tools frontend(s) with an imperative UI command from
# the backend (ADR 0025, op::FE_COMMAND). A BE-side CLI: it frames an
# `fe.command.send` request, sends it to the running sotd daemon over its
# socket (no comm relay, no FE LLM), and the daemon re-emits it as an
# `fe.command` evt to every connected frontend. The FE switches + shows the
# target regardless of its current view (badge floor without --fe; force-show
# to one FE with --fe <handle>).
#
# Usage:
#   sot-fe preview <workspace> <path> [--urgent] [--fe <handle>] [--roi x,y,w,h]
#   sot-fe reveal  <workspace> <path> [--urgent] [--fe <handle>]
#   sot-fe goto    <workspace>        [--boot] [--fe <handle>]
#   sot-fe mode    <mode>             [--fe <handle>]
#   sot-fe notify  <text> [--level <l>] [--ws <workspace>] [--fe <handle>]
#   sot-fe docs    <workspace> <abs-path>          [--fe <handle>]
#   sot-fe repl run  <workspace> <path>            [--fresh] [--timeout <s>] [--origin <who>]
#   sot-fe repl eval <workspace> (--code <c> | --stdin) [--timeout <s>] [--origin <who>]
#
#   preview  — switch the FE to <workspace>, Files mode, and preview <path>.
#   reveal   — switch + reveal <path> in the file tree (cursor it, no preview).
#   goto     — switch the FE to <workspace> (no path).
#   mode     — switch the FE's active mode (files | modules | project | ...).
#   notify   — surface a one-line notice (optionally scoped to a workspace).
#   open-url — open an http(s) URL in the FE machine's OS BROWSER (not a
#              forwarded port — the FE just opens it). Broadcast opens on
#              every attached FE; use --fe to target one.
#   docs     — open a LOCAL .html/site (ABSOLUTE backend path) in the FE's OS
#              BROWSER via docs.open (the `W` key, backend-triggered): the FE
#              serves the file from backend disk over the forwarded site_serve
#              port and opens it — runs JS/WebGL, no preview size caps. For a
#              built site or a self-contained figure export. NOT an http URL
#              (use open-url for those); path is confined to a workspace root.
#   repl     — run a .jl file (or eval code) in a workspace's persistent REPL
#              and print the COLLECTED output (stdout/stderr/value/error +
#              figure file paths). Unlike the other verbs this is a real
#              request/response op (repl.execute, ADR 0033): it blocks until
#              the run finishes (or --timeout, default 120s) and returns the
#              output. Non-destructive — runs in the REPL's current project,
#              no reset. Exit 0 on outcome:ok, 2 otherwise.
#
#   --fe <handle>  scope delivery to one FE by its sot-comm handle (sets the
#                  wire `target`); absent = every FE acts (the badge floor).
#   --urgent       hint the FE to force-show now (preview/reveal); sets args.urgent.
#   --roi x,y,w,h   (preview) aim the viewport at a SOURCE-IMAGE-PIXEL rect (ADR-0022
#                  image.crop vocabulary; round-trippable). FE clamps to image bounds.
#                  The effective (clamped) rect echoes via a follow-up event, not this
#                  fire-and-forget ack (ADR-0025 2026-07-21 Update).
#   --boot         (goto) seed autostart so the FE boots ccb on the switch — the
#                  scriptable spawn->goto->boot primitive. Send DIRECTED (--fe
#                  <handle>); a broadcast --boot would switch+boot on EVERY FE.
#   --fresh        (repl run) RESTART the workspace's persistent REPL into
#                  <path>'s project before including it (op repl.run_file,
#                  fresh:true) — the way to clear a STALE kernel from a backend
#                  session (e.g. after a struct/field change Revise can't
#                  hot-reload). Fire-and-forget: acks the bounce; the include's
#                  output streams to the FE drawer, not collected here. Without
#                  --fresh, `repl run` uses repl.execute (no reset, collects
#                  output) in the REPL's CURRENT project.
#   --endpoint     daemon address; else $SOT_FE_ENDPOINT / $SOT_SPAWN_ENDPOINT /
#                  $SOT_SOCKET / auto-detected from the running sotd daemon.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/comm-lib.sh"

if ! command -v jq >/dev/null 2>&1; then
    echo "ERROR: jq not found — needed to build the request payload." >&2; exit 1
fi
# nc is preferred, but git-bash on Windows ships none — so for TCP endpoints we
# fall back to bash's /dev/tcp (see sot_send). Only a unix-socket endpoint hard-
# requires nc -U (/dev/tcp can't speak AF_UNIX). Mirrors comm-relay.sh's
# fallback so sot-fe works on Windows without netcat.
HAVE_NC=0; command -v nc >/dev/null 2>&1 && HAVE_NC=1

usage() {
    # Print the header usage/description block: comment lines from 10 down to
    # the first non-comment line (robust to the block growing).
    sed -n '10,$ { /^[^#]/q; p; }' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-1}"
}

CMD="${1:-}"; [ -n "$CMD" ] && shift || usage 1
ENDPOINT=""
FE=""          # --fe handle → wire `target`
URGENT=false
BOOT=false
LEVEL=""
NOTIFY_WS=""
TIMEOUT=""     # repl: wall-clock budget in seconds
CODE=""        # repl eval: code (else read stdin)
READ_STDIN=false
ORIGIN=""      # repl: label shown in the user's drawer (default "session")
ROI=""         # preview: source-px rect "x,y,w,h" to frame the image at (ADR-0022 vocab)
FRESH=false    # repl run: restart the persistent REPL into the file's project
POS=()         # positional args for the subcommand
while [ $# -gt 0 ]; do
    case "$1" in
        --fe)       FE="$2"; shift 2 ;;
        --endpoint) ENDPOINT="$2"; shift 2 ;;
        --urgent)   URGENT=true; shift ;;
        --boot)     BOOT=true; shift ;;
        --fresh)    FRESH=true; shift ;;
        --level)    LEVEL="$2"; shift 2 ;;
        --ws)       NOTIFY_WS="$2"; shift 2 ;;
        --timeout)  TIMEOUT="$2"; shift 2 ;;
        --code)     CODE="$2"; shift 2 ;;
        --stdin)    READ_STDIN=true; shift ;;
        --origin)   ORIGIN="$2"; shift 2 ;;
        --roi)      ROI="$2"; shift 2 ;;
        -h|--help)  usage 0 ;;
        # Hard-error on an UNKNOWN flag instead of silently treating it as a
        # positional — a silent drop let `repl run --fresh` return a false "ok"
        # while ignoring --fresh entirely. Positionals never start with '-'.
        -?*)        echo "ERROR: unknown flag '$1'" >&2; usage 1 ;;
        *)          POS+=("$1"); shift ;;
    esac
done

# --- resolve the daemon endpoint ---
resolve_endpoint() {
    sot_daemon_endpoint "${ENDPOINT:-${SOT_FE_ENDPOINT:-${SOT_SPAWN_ENDPOINT:-}}}"
}

# Send a frame to the daemon, return the first response line matching op $2.
# Uses nc when present; otherwise falls back to bash /dev/tcp for tcp endpoints
# (so this works in git-bash on Windows). A unix-socket endpoint still needs
# nc -U. The exec lives in a subshell: a redirect-only exec whose redirect fails
# would otherwise EXIT a non-interactive shell outright (same class as the
# comm-relay.sh /dev/tcp fix).
# App-level auth (ADR 0010 hardening): the daemon requires a token-valid hello
# before serving any op, so prepend one to every connection. Empty token = open
# mode (gate off). The hello reply is ignored — sot_send greps by op.
_sot_hello() {
    local tok; tok="${SOT_TOKEN:-$(cat "${XDG_CONFIG_HOME:-$HOME/.config}/sot/token" 2>/dev/null || true)}"
    printf '{"v":1,"id":1,"kind":"req","op":"hello","payload":{"client_id":"sot-comm","last_seen_revision":0,"protocol":1,"app_version":"comm","token":"%s"}}\n' "$tok"
}
sot_send() {
    local frame="$1" op="$2" hp host port
    case "$ENDPOINT" in
        tcp:*)
            hp="${ENDPOINT#tcp:}"; host="${hp%:*}"; port="${hp##*:}"
            if [ "$HAVE_NC" = 1 ]; then
                { _sot_hello; printf '%s\n' "$frame"; } | timeout "${SEND_TIMEOUT:-6}" nc "$host" "$port" 2>/dev/null | grep -m1 "\"op\":\"$op\""
            else
                (
                    exec 9<>"/dev/tcp/$host/$port" \
                        || { echo "ERROR: /dev/tcp connect to $host:$port failed (and nc not found)" >&2; exit 1; }
                    { _sot_hello; printf '%s\n' "$frame"; } >&9
                    timeout "${SEND_TIMEOUT:-6}" cat <&9
                    exec 9<&- 9>&- 2>/dev/null || true
                ) | grep -m1 "\"op\":\"$op\""
            fi
            ;;
        unix:*)
            if [ "$HAVE_NC" = 1 ]; then
                { _sot_hello; printf '%s\n' "$frame"; } | timeout "${SEND_TIMEOUT:-6}" nc -U "${ENDPOINT#unix:}" 2>/dev/null | grep -m1 "\"op\":\"$op\""
            else
                echo "ERROR: nc not found and endpoint is a unix socket (needs nc -U)" >&2; return 1
            fi
            ;;
        *) return 1 ;;
    esac
}

# Frame an `fe.command.send` req from a cmd verb ($1) + an args JSON object ($2),
# attaching `target` from --fe when set, and send it to the daemon.
send_fe_command() {
    local fe_cmd="$1" args_json="$2"
    if ! ENDPOINT="$(resolve_endpoint)"; then
        echo "ERROR: could not find the sotd daemon. Set --endpoint unix:/path or tcp:HOST:PORT (or \$SOT_FE_ENDPOINT)." >&2
        exit 1
    fi
    local payload
    if [ -n "$FE" ]; then
        payload="$(jq -nc --arg c "$fe_cmd" --argjson a "$args_json" --arg t "$FE" \
            '{cmd:$c, args:$a, target:$t}')"
    else
        payload="$(jq -nc --arg c "$fe_cmd" --argjson a "$args_json" \
            '{cmd:$c, args:$a}')"
    fi
    local req
    req="$(jq -nc --argjson p "$payload" \
        '{v:1, id:1, kind:"req", op:"fe.command.send", payload:$p}')"
    local resp
    resp="$(sot_send "$req" fe.command.send || true)"
    local ok
    ok="$(printf '%s' "$resp" | jq -r '.payload.ok // empty' 2>/dev/null || true)"
    if [ "$ok" != "true" ]; then
        echo "ERROR: fe.command.send ($fe_cmd) failed via $ENDPOINT" >&2
        [ -n "$resp" ] && printf '  daemon said: %s\n' "$resp" >&2
        exit 1
    fi
    echo "fe.command sent: cmd=$fe_cmd${FE:+ target=$FE} via $ENDPOINT"
    # Two sessions burned on the same traps (MyAnalysis, MyDocs) — say the
    # delivery semantics out loud instead of letting 'sent' read as 'shown'.
    if [ -n "${FE:-}" ]; then
        case "$FE" in
            win-fe-*) ;; # a real per-host handle
            *) echo "WARNING: --fe '$FE' is not a per-host handle (win-fe-<host>); FEs self-filter on their EXACT handle, so this likely matched NO frontend and was dropped silently. Omit --fe to reach all FEs." >&2 ;;
        esac
        echo "note: --fe/--urgent are deprecated (2026-06-29, badge-floor only — we never force-switch the user's view)." >&2
    fi
    case "$fe_cmd" in
        preview|reveal)
            echo "note: badges the target workspace row — the user is never yanked; when they visit that workspace the file is cursored in the nav AND rendered in the preview (complete show, always). --urgent --fe <handle> is the user-requested focus-capture option." ;;
    esac
}

# Send a repl.execute request (ADR 0033) and print the collected result. $1 is
# the `input` JSON object ({kind:"run_file",path} | {kind:"eval",code}); $2 is
# the workspace. Unlike send_fe_command this is a real request/response op — it
# blocks for the run and the daemon returns the collected output on this op's
# res line (the interleaved repl.frame evts on the connection are skipped by
# sot_send's op-grep). Exits 2 on a non-ok outcome.
send_repl_execute() {
    local input_json="$1" ws="$2"
    if ! ENDPOINT="$(resolve_endpoint)"; then
        echo "ERROR: could not find the sotd daemon. Set --endpoint unix:/path or tcp:HOST:PORT (or \$SOT_FE_ENDPOINT)." >&2
        exit 1
    fi
    local secs="${TIMEOUT:-120}"
    local ms=$(( secs * 1000 ))
    # Wait a little past the backend budget so the daemon's timeout result (not
    # our socket read) is what lands.
    export SEND_TIMEOUT=$(( secs + 10 ))
    local payload req resp
    payload="$(jq -nc --arg w "$ws" --argjson in "$input_json" --argjson t "$ms" \
        '{workspace_id:$w, input:$in, timeout_ms:$t}')"
    [ -n "$ORIGIN" ] && payload="$(printf '%s' "$payload" | jq -c --arg o "$ORIGIN" '. + {origin:$o}')"
    req="$(jq -nc --argjson p "$payload" '{v:1, id:2, kind:"req", op:"repl.execute", payload:$p}')"
    resp="$(sot_send "$req" repl.execute || true)"
    if [ -z "$resp" ]; then
        echo "ERROR: no response from repl.execute within ${SEND_TIMEOUT}s via $ENDPOINT. The eval is ENQUEUED before any reply is written, so a missing response — whether a TIMEOUT (first REPL use per workspace precompiles its deps, minutes) OR a connection dropped AFTER enqueue — does NOT mean nothing ran: your eval MAY STILL BE RUNNING. Do NOT re-run blindly — check the drawer/output first; re-running would execute it TWICE (double side-effects: files written twice, state mutated twice)." >&2
        exit 1
    fi
    printf '%s' "$resp" | jq -r '
        .payload as $p |
        if ($p.error != null) and (($p.outcome // "") == "") then
            "ERROR: \($p.error) [\($p.code // "?")]"
        else
            "outcome: \($p.outcome)   run_id: \($p.run_id)   elapsed: \($p.elapsed_ms)ms"
            + (if ($p.outcome == "timeout") then "\n⚠ TIMEOUT is NOT failed or cancelled: run_id \($p.run_id) exceeded the reply budget but is STILL RUNNING in the REPL (first REPL use per workspace precompiles its package deps — can take minutes). Do NOT re-run — check run_id \($p.run_id) / the drawer for its output; re-running would execute it a SECOND time (double side-effects: files written twice, state mutated twice)." else "" end)
            + (if $p.truncated then "   [output truncated]" else "" end)
            + (if ($p.project_dir // "") != "" then "\nproject: \($p.project_dir) (\($p.project_source // "?"))" else "" end)
            + (if ($p.stdout // "") != "" then "\n--- stdout ---\n\($p.stdout)" else "" end)
            + (if ($p.stderr // "") != "" then "\n--- stderr ---\n\($p.stderr)" else "" end)
            + (if (($p.values // []) | length) > 0 then "\n--- value ---\n" + ($p.values | map(.text) | join("\n")) else "" end)
            + (if $p.error != null then "\n--- error ---\n\($p.error.message)" + (($p.error.stacktrace // []) | map("\n  at \(.fn) (\(.file):\(.line))") | join("")) else "" end)
            + (if (($p.figures // []) | length) > 0 then "\n--- figures ---\n" + ($p.figures | join("\n")) else "" end)
        end
    '
    local outcome
    outcome="$(printf '%s' "$resp" | jq -r '.payload.outcome // "error"')"
    [ "$outcome" = "ok" ] || exit 2
}

# Send a repl.run_file request with fresh:true — RESTART the workspace's
# persistent REPL into <path>'s project (daemon: restart_with_project), then
# include the file in the fresh kernel. This is the kernel-bounce path (clears a
# stale in-memory package a struct/field change can't hot-reload; Revise is not
# wired in). Unlike repl.execute this is FIRE-AND-FORGET: the daemon acks once
# the restart is spawned (with project_dir/source); the include's frames stream
# as repl.frame evts to the FE drawer and are NOT collected here. $1=path
# $2=workspace. Exits 2 on a failed ack.
send_repl_run_file() {
    local file="$1" ws="$2"
    if ! ENDPOINT="$(resolve_endpoint)"; then
        echo "ERROR: could not find the sotd daemon. Set --endpoint unix:/path or tcp:HOST:PORT (or \$SOT_FE_ENDPOINT)." >&2
        exit 1
    fi
    # The restart spawns a fresh julia child before the ack; give it more room
    # than sot_send's 6s default (honour --timeout if the caller set it).
    export SEND_TIMEOUT="${TIMEOUT:-30}"
    local payload req resp
    # ReplRunFileReq: eval_id(u64)+path required, fresh:true, workspace_id routes
    # to the target REPL. eval_id only correlates streamed frames we don't
    # collect, so a fixed value is fine.
    payload="$(jq -nc --arg p "$file" --arg w "$ws" \
        '{eval_id:1, path:$p, fresh:true, workspace_id:$w}')"
    req="$(jq -nc --argjson p "$payload" '{v:1, id:2, kind:"req", op:"repl.run_file", payload:$p}')"
    resp="$(sot_send "$req" repl.run_file || true)"
    if [ -z "$resp" ]; then
        echo "ERROR: no ack from repl.run_file within ${SEND_TIMEOUT}s via $ENDPOINT. The request is ENQUEUED before any ack is written, so a missing ack (timeout OR a connection dropped after enqueue) does NOT mean nothing happened — the fresh-restart may have ALREADY bounced the workspace REPL into <path>'s project and started the include. Check the drawer for a fresh REPL before re-running, or you'll re-bounce it (and re-run the file)." >&2
        exit 1
    fi
    # Ack is either {error,code} or {project_dir,project_source,accepted:true}.
    printf '%s' "$resp" | jq -r '
        .payload as $p |
        if ($p.error != null) then
            "ERROR: \($p.error) [\($p.code // "?")]"
        else
            "fresh-run accepted: REPL restarted into \($p.project_dir // "?") (\($p.project_source // "?"))"
            + "\nnote: kernel bounced; \($p.path // "the file") is being included in the fresh process. Output streams to the FE drawer, not collected here."
        end
    '
    local err
    err="$(printf '%s' "$resp" | jq -r '.payload.error // empty')"
    [ -z "$err" ] || exit 2
}

case "$CMD" in
    preview|reveal)
        WS="${POS[0]:-}"; PATH_ARG="${POS[1]:-}"
        [ -n "$WS" ] && [ -n "$PATH_ARG" ] || { echo "usage: sot-fe $CMD <workspace> <path> [--urgent] [--fe <handle>] [--roi x,y,w,h]" >&2; exit 1; }
        # Keep the file nav INSIDE the repo: a node_id must be REPO-RELATIVE (the
        # daemon rejects absolute node_ids, and the FE tree positions its cursor by
        # relative id — an absolute path would show a "floating" file the nav can't
        # follow). Agents naturally hold an ABSOLUTE path of a file they just made,
        # so relativize it here against the caller's repo root. The strip is LEXICAL
        # (string prefix) — NOT `git -C <dir>` / realpath on the file — so a file
        # under a symlinked dir (e.g. data/results/myproject -> external storage) keeps its
        # in-repo relative path instead of resolving out to the external storage root.
        case "$PATH_ARG" in
            /*)
                _repo_root="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
                if [ -n "$_repo_root" ] && [ "$PATH_ARG" != "${PATH_ARG#"$_repo_root"/}" ]; then
                    PATH_ARG="${PATH_ARG#"$_repo_root"/}"
                else
                    echo "ERROR: '$PATH_ARG' is absolute and not under the current repo (${_repo_root:-<not in a repo>}). Pass a path relative to the workspace root — the file nav can only show files inside the repo." >&2
                    exit 1
                fi
                ;;
        esac
        ARGS="$(jq -nc --arg w "$WS" --arg p "$PATH_ARG" '{workspace:$w, path:$p}')"
        [ "$URGENT" = true ] && ARGS="$(printf '%s' "$ARGS" | jq -c '. + {urgent:true}')"
        # --roi x,y,w,h: aim the FE viewport at a SOURCE-IMAGE-PIXEL rect (ADR-0022
        # `image.crop` vocabulary, so a crop taken now round-trips to "look here
        # again" later — same rect = same region on any display). Validate strictly
        # CLI-side; the FE clamps to image bounds (zoom via png_zoom_max, pan-slack)
        # and, being fire-and-forget, does NOT echo the effective rect in this ack
        # (see ADR-0025 addendum) — a heavily-clamped aim surfaces FE-side.
        if [ -n "$ROI" ]; then
            IFS=',' read -r RX RY RW RH RREST <<< "$ROI"
            for _n in "$RX" "$RY" "$RW" "$RH"; do
                case "$_n" in
                    ''|*[!0-9]*) echo "ERROR: --roi expects x,y,w,h as non-negative integers (source-image px), got '$ROI'" >&2; exit 1 ;;
                esac
            done
            [ -z "$RREST" ] || { echo "ERROR: --roi expects exactly 4 comma-separated values x,y,w,h, got '$ROI'" >&2; exit 1; }
            # base-10 normalize (strips leading zeros so jq --argjson stays valid JSON)
            RX=$((10#$RX)); RY=$((10#$RY)); RW=$((10#$RW)); RH=$((10#$RH))
            { [ "$RW" -gt 0 ] && [ "$RH" -gt 0 ]; } || { echo "ERROR: --roi w and h must be > 0 (zero-area rect), got w=$RW h=$RH" >&2; exit 1; }
            ARGS="$(printf '%s' "$ARGS" | jq -c --argjson x "$RX" --argjson y "$RY" --argjson w "$RW" --argjson h "$RH" '. + {roi:{x:$x,y:$y,w:$w,h:$h}}')"
        fi
        send_fe_command "$CMD" "$ARGS"
        # Use `if`, NOT `[ -n "$ROI" ] && echo` — with `set -e` and this being the
        # script's last statement, a false `[ -n "" ]` test (the no-ROI common case)
        # is exit status 1 and becomes the WHOLE script's exit code, so a perfectly
        # successful badge reported failure to careful callers (HS-TIRF, 2026-07-23:
        # open-url exits 0, preview exited 1 on identical success). `if` returns 0
        # when the condition is false.
        if [ -n "$ROI" ]; then
            echo "  roi requested (source px): x=$RX y=$RY w=$RW h=$RH — FE clamps to image bounds" >&2
        fi
        ;;
    docs)
        WS="${POS[0]:-}"; PATH_ARG="${POS[1]:-}"
        [ -n "$WS" ] && [ -n "$PATH_ARG" ] || { echo "usage: sot-fe docs <workspace> <abs-path> [--fe <handle>]" >&2; exit 1; }
        # docs.open (the FE `W` key, backend-triggered) serves a LOCAL .html/site
        # from backend disk over the forwarded site_serve port and opens it in the
        # FE's real browser (runs JS/WebGL, no preview size caps). Unlike
        # preview/reveal it needs an ABSOLUTE backend path — the daemon stats it
        # RAW and confines it to any workspace root, so a repo-relative node_id
        # would be resolved against sotd's CWD and fail. Refuse a relative path
        # rather than send a broken one; do NOT relativize.
        case "$PATH_ARG" in
            /*) : ;;
            *)  echo "ERROR: sot-fe docs needs an ABSOLUTE backend path (docs.open stats it raw, not a repo-relative node_id)." >&2; exit 1 ;;
        esac
        ARGS="$(jq -nc --arg w "$WS" --arg p "$PATH_ARG" '{workspace:$w, path:$p}')"
        send_fe_command docs "$ARGS"
        ;;
    goto)
        WS="${POS[0]:-}"
        [ -n "$WS" ] || { echo "usage: sot-fe goto <workspace> [--boot] [--fe <handle>]" >&2; exit 1; }
        if [ "$BOOT" = true ]; then
            ARGS="$(jq -nc --arg w "$WS" '{workspace:$w, boot:true}')"
        else
            ARGS="$(jq -nc --arg w "$WS" '{workspace:$w}')"
        fi
        send_fe_command goto_workspace "$ARGS"
        ;;
    mode)
        MODE="${POS[0]:-}"
        [ -n "$MODE" ] || { echo "usage: sot-fe mode <mode> [--fe <handle>]" >&2; exit 1; }
        ARGS="$(jq -nc --arg m "$MODE" '{mode:$m}')"
        send_fe_command goto_mode "$ARGS"
        ;;
    notify)
        TEXT="${POS[0]:-}"
        [ -n "$TEXT" ] || { echo "usage: sot-fe notify <text> [--level <l>] [--ws <workspace>] [--fe <handle>]" >&2; exit 1; }
        ARGS="$(jq -nc --arg t "$TEXT" '{text:$t}')"
        [ -n "$LEVEL" ]     && ARGS="$(printf '%s' "$ARGS" | jq -c --arg l "$LEVEL" '. + {level:$l}')"
        [ -n "$NOTIFY_WS" ] && ARGS="$(printf '%s' "$ARGS" | jq -c --arg w "$NOTIFY_WS" '. + {workspace:$w}')"
        send_fe_command notify "$ARGS"
        ;;
    open-url)
        URL="${POS[0]:-}"
        case "$URL" in
            http://*|https://*) : ;;
            *) echo "usage: sot-fe open-url <http(s)-url> [--fe <handle>]  (http/https only)" >&2; exit 1 ;;
        esac
        ARGS="$(jq -nc --arg u "$URL" '{url:$u}')"
        send_fe_command open_url "$ARGS"
        ;;
    repl)
        SUB="${POS[0]:-}"
        case "$SUB" in
            run)
                WS="${POS[1]:-}"; FILE="${POS[2]:-}"
                [ -n "$WS" ] && [ -n "$FILE" ] || { echo "usage: sot-fe repl run <workspace> <path> [--fresh] [--timeout <s>]" >&2; exit 1; }
                if [ "$FRESH" = true ]; then
                    # Bounce the persistent REPL into <path>'s project, then include.
                    send_repl_run_file "$FILE" "$WS"
                else
                    INPUT="$(jq -nc --arg p "$FILE" '{kind:"run_file", path:$p}')"
                    send_repl_execute "$INPUT" "$WS"
                fi
                ;;
            eval)
                WS="${POS[1]:-}"
                [ -n "$WS" ] || { echo "usage: sot-fe repl eval <workspace> (--code <c> | --stdin) [--timeout <s>]" >&2; exit 1; }
                EVAL_CODE=""
                if [ "$READ_STDIN" = true ]; then
                    EVAL_CODE="$(cat)"
                elif [ -n "$CODE" ]; then
                    EVAL_CODE="$CODE"
                else
                    echo "usage: sot-fe repl eval <workspace> (--code <c> | --stdin)  — code from --code or piped stdin" >&2; exit 1
                fi
                INPUT="$(jq -nc --arg c "$EVAL_CODE" '{kind:"eval", code:$c}')"
                send_repl_execute "$INPUT" "$WS"
                ;;
            *) echo "usage: sot-fe repl run <workspace> <path> | sot-fe repl eval <workspace> (--code <c> | --stdin)" >&2; exit 1 ;;
        esac
        ;;
    -h|--help|help) usage 0 ;;
    *) echo "ERROR: unknown subcommand '$CMD'" >&2; usage 1 ;;
esac
